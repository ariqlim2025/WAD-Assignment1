<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit community &middot; Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>
    <section class="main-content">
        <a href="/communities/<%= communitySlug %>" class="back-link">&larr; Back to community</a>

        <% if (otherError) { %>
            <div class="community-form-card">
                <div class="community-label-row">
                    <span class="error-label"><%= otherError %></span>
                </div>
            </div>
        <% } else { %>

            <div class="community-form-card">
                <h2 class="community-form-title">Update Community</h2>

                <form class="community-form" action="/communities/<%= communitySlug %>/edit" method="post">
                    <div class="community-form-field">
                        <label for="community">Enter Community Name:</label>
                        <input class="community-input" type="text" name="community" id="community" value="<%= community_name %>" required>
                    </div>

                    <div class="community-form-field">
                        <label for="description">Enter Community Description:</label>
                        <textarea class="community-textarea" name="description" id="description" rows="5" required><%= description_details%></textarea>
                    </div>

                    <button type="submit" class="community-submit-btn">Save changes</button>
                </form>

                <% if (communityNameError || communityDescriptionError) { %>
                    <p class="community-feedback community-feedback-error"><%= communityNameError %></p>
                    <p class="community-feedback community-feedback-error"><%= communityDescriptionError %></p>
                <% } %>
            </div>
        <% } %>
    </section>
</body>
</html>



