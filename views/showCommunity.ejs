<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WADsUp</title>
    <link rel="icon" type="image/png" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <%- include('header') %>

    <!-- Main Content -->
    <section class="main-content">
        
        <a href="/create-community" class="create-post-btn">+ Create Community</a>

        <!-- View all the posts here -->
        <% if (communities.length === 0) { %>
            <p class="no-posts">No communities yet. Be the first to create a community!</p>
        <% } else { %>
            <% for (let i = 0; i < communities.length; i++) { %>
                <div class="post-card">
                    <!-- Post Content -->
                    <div class="post-content">

                        <a href="" class="community-title">
                            <h3><%= communities[i].name %></h3>
                        </a>
                        <p class="post-author"><%= communities[i].description %></p>
                    </div>
                </div>
            <% } %>
        <% } %>
    </section>

</body>
</html>