<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WADsUp</title>
    <link rel="icon" type="image/png" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>

    <section class="main-content">
        
        <!-- back button -->
        <p style="color: #fff; margin-bottom: 12px;"><a href="/communities" style="color: #9ec5ff;">← Back to communities</a></p>
        
        <div class="community-form-card">
            <h2 class="community-form-title">Create Community</h2>

            <form class="community-form" action="/create-community" method="post">
                <div class="community-form-field">
                    <label for="community">Enter Community Name:</label>
                    <input class="community-input" type="text" name="community" id="community" value="<%= community_name %>" required>
                </div>

                <div class="community-form-field">
                    <label for="description">Enter Community Description:</label>
                    <textarea class="community-textarea" name="description" id="description" rows="5" required><%= description_details%></textarea>
                </div>

                <button type="submit" class="community-submit-btn">Create</button>
            </form>

            <% if (community_name && description_details && !communityNameError && !communityDescriptionError) { %>
                <p class="community-feedback community-feedback-success">Successfully created Community: <%= community_name %></p>
                <p class="community-feedback community-feedback-success">Description: <%= description_details %></p>
            <% } else { %>
                <% if (communityNameError) { %>
                    <p class="community-feedback community-feedback-error"><%= communityNameError %></p>
                <% } %>
                <% if (communityDescriptionError) { %>
                    <p class="community-feedback community-feedback-error"><%= communityDescriptionError %></p>
                <% } %>
            <% } %>
        </div>
    </section>
</body>
</html>