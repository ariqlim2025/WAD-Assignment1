<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-page">
        <div class="form-card">
            <h1>Reset your password</h1>
            <form action="/forgetPass" method="get" <%= emailExists ? "hidden" : "" %>>
                <h3><%= emailError %></h3>
                <div class="form-field">
                    <label>Enter your email:</label>
                    <input type="email" name="email" value="<%= email %>" required>
                </div>
                <input type="submit" value="Submit">
                <a href="/login"><input type="button" value="Back"></a>
            </form>
            <form action="/forgetPass" method="post" <%= emailExists && (passError || !password)  ? "" : "hidden" %>>
                <input type="email" name="email" value="<%= email %>" hidden>
                <div class="form-field">
                    <ul class="user-error-msg"><strong><%- passError %></strong></ul>
                    <label>Password</label>
                    <input type="password" name="password" required>
                </div>
                <div class="form-field">
                    <label>Confirm Password</label>
                    <input type="password" name="confirmPassword" required>
                </div>
                <input type="submit" value="Submit">
            </form>
            <p <%= emailExists && !passError && password ? "" : "hidden" %>>Password updated! <a href="/login">Login here</a></p>
        </div>
    </div>
</body>
</html>



