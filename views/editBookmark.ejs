<html>
<head></head>
<body>

  <h1>Edit Bookmark</h1>
  <hr>
  <p>
    <a href="/posts/<%= bookmark.postId._id %>">Back to Post</a>
    &nbsp;|&nbsp;
    <a href="/bookmarks">Back to Bookmarks</a>
    &nbsp;|&nbsp;
    <a href="/">Back to Home</a>
  </p>

  <% if (bookmarkError) { %>
    <p style="color: #c62828;"><strong><%= bookmarkError %></strong></p>
  <% } %>

  <% if (success) { %>
    <p style="color: #2e7d32;"><strong><%= bookmarkSuccess || 'Bookmark updated successfully!' %></strong></p>
  <% } %>

  <h3><%= bookmark.postId.title %></h3>

  <form action="/bookmarks/edit" method="POST">
    <input type="hidden" name="postId" value="<%= bookmark.postId._id %>">
    <p><label for="note"><strong>Note</strong></label></p>
    <textarea name="note" id="note" rows="4" cols="40" required><%= bookmark.note %></textarea>
    <br><br>
    <button type="submit">Save</button>
  </form>

</body>
</html>
