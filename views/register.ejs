<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-page">
        <p><a href="/index.html" class="back-link">&larr; Back to Wadsup</a></p>

        <div class="auth-logo-bridge">
            <img src="/assets/app-logo-2.png" alt="Wadsup logo" class="auth-logo-bridge-img">
        </div>

        <div class="auth-intro-card">
            <h2>Wadsup</h2>
            <p>Wadsup is a community forum where people share posts, join communities, comment, vote, and save bookmarks.</p>
        </div>

        <div class="form-card" <%= success ? "hidden" : "" %>>
            <form action="/register" method="post">
                <h1>Register</h1>
                <div class="form-field">
                    <ul class="user-error-msg"><strong><%- usernameError %></strong></ul>
                    <label>Username</label>
                    <input type="text" name="username" value="<%= username %>" required>
                </div>
                <div class="form-field">
                    <ul class="user-error-msg"><strong><%- emailError %></strong></ul>
                    <label>Email</label>
                    <input type="email" name="email" value="<%= email %>" required>
                </div>
                <div class="form-field">
                    <ul class="user-error-msg"><strong><%- passError %></strong></ul>
                    <label>Password</label>
                    <input type="password" name="password" required>
                </div>
                <div class="form-field">
                    <label>Confirm Password</label>
                    <input type="password" name="confirmPassword" required>
                </div>
                <div class="form-field">
                    <ul class="user-error-msg"><strong><%- ageError %></strong></ul>
                    <label>Date of Birth</label>
                    <input type="date" name="dateBirth" value="<%= dateBirth %>" required>
                </div>
                <input type="submit" value="Register">
            </form>
            <p>Already have an account? Log in <a href="/login">here.</a></p>
        </div>
        <div class="form-card" <%= success ? "" : "hidden" %>>
            <h2>Registration successful! Please log in now.</h2>
            <p><a href="/login"><input type="button" value="Log in"></a></p>
        </div>
    </div>
</body>
</html>





