<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Bookmarks &middot; Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <section class="main-content">
        <a href="/home" class="back-link">&larr; Back to Home</a>

        <h1>My Bookmarks</h1>

        <% if (bookmarkError) { %>
            <p class="msg-error"><strong><%= bookmarkError %></strong></p>
        <% } %>

        <% if (bookmarkSuccess) { %>
            <p class="msg-success"><strong><%= bookmarkSuccess %></strong></p>
        <% } %>

        <p>You have <strong><%= bookmarkList.length %></strong> bookmark(s)</p>

        <table class="bookmark-table">
            <thead>
                <tr>
                    <th>Post</th>
                    <th>Note</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% for (let bookmark of bookmarkList) { %>
                    <tr>
                        <td><%= bookmark.postId.title %></td>
                        <td><%= bookmark.note %></td>
                        <td>
                            <a href="/posts/<%= bookmark.postId._id %>">View Post</a>
                            &nbsp;
                            <a href="/bookmarks/edit?postId=<%= bookmark.postId._id %>">Edit</a>
                            &nbsp;
                            <form action="/bookmarks/delete" method="post" class="post-actions__form">
                                <input type="hidden" name="postId" value="<%= bookmark.postId._id %>">
                                <button type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </section>
</body>
</html>



