<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-page">
        <div class="form-card">
            <form action="/profile" method="post">
                <ul class="user-error-msg">
                    <%- userError %>
                    <%- emailError %>
                </ul>
                <h1><%- updated ? "Updated!" : "Profile" %></h1>
                <table>
                    <tr>
                        <td colspan="2"><h3>Username</h3></td>
                    </tr>
                    <tr>
                        <td><input type="text" name="username" value="<%= username %>" id="usernameInput" required readonly></td>
                        <td><input type="checkbox" id="usernameCheck" name="usernameCheck">Edit?</td>
                    </tr>
                    <tr>
                        <td colspan="2"><h3>Email</h3></td>
                    </tr>
                    <tr>
                        <td><input type="email" name="email" value="<%= email %>" id="emailInput" required readonly></td>
                        <td><input type="checkbox" id="emailCheck" name="emailCheck">Edit?</td>
                    </tr>
                    <tr>
                        <td colspan="2"><h3>Bio</h3></td>
                    </tr>
                    <tr>
                        <td><textarea name="bio" rows="5" cols="25" id="bioInput" readonly><%= bio %></textarea></td>
                        <td><input type="checkbox" id="bioCheck" name="bioCheck">Edit?</td>
                    </tr>
                </table>
                <input type="submit" value="Apply change" id="applyBtn" disabled>
                <script>
                    const usernameCheck = document.getElementById('usernameCheck');
                    const emailCheck = document.getElementById('emailCheck');
                    const bioCheck = document.getElementById('bioCheck');

                    const userInput = document.getElementById('usernameInput');
                    const emailInput = document.getElementById('emailInput');
                    const bioInput = document.getElementById('bioInput');

                    const applyBtn = document.getElementById('applyBtn');

                    const originalValues = {username: userInput.value, email: emailInput.value, bio: bioInput.value };

                    usernameCheck.addEventListener('change', function () { userInput.readOnly = !this.checked; });
                    emailCheck.addEventListener('change', function () { emailInput.readOnly = !this.checked; });
                    bioCheck.addEventListener('change', function () { bioInput.readOnly = !this.checked; });

                    usernameCheck.addEventListener('change', updateButton);
                    emailCheck.addEventListener('change', updateButton);
                    bioCheck.addEventListener('change', updateButton);

                    userInput.addEventListener('input', updateButton);
                    emailInput.addEventListener('input', updateButton);
                    bioInput.addEventListener('input', updateButton);

                    function updateButton() {
                        applyBtn.disabled = !hasChanges();
                    }

                    function hasChanges() {
                        return (
                            usernameCheck.checked && userInput.value !== originalValues.username ||
                            emailCheck.checked && emailInput.value !== originalValues.email ||
                            bioCheck.checked && bioInput.value !== originalValues.bio
                        );
                    }
                </script>
            </form>
            <p><a href="/deleteAccount"><input type="button" value="Delete Account"></a></p>
            <p><a href="/"><input type="button" value="Back"></a></p>
        </div>
    </div>
</body>
</html>



