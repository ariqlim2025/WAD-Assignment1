<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WADsUp</title>
    <link rel="icon" type="image/png" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <nav>
        <div class="nav-logo">
            <img src="/assets/app-logo-2.png" alt="WADsUP Logo">
            <a href="/">WADsUP</a>
        </div>

        <div class="nav-tagline">Your Daily KetchUp</div>

        <!-- If user is not logged in, display register / login buttons -->
        <% if (!user_id){ %>
            <div>
                <a href="/login" class="nav-btn">Log-in</a>
                <a href="/register" class="nav-btn">Register</a>
            </div>
        <% } else { %>
            <!-- user is logged in, display logout /profile button -->
            <div>
                <a href="" class="nav-btn">LogOut</a>
                <a href="/profile" class="nav-btn">Profile</a>
            </div>
        <% } %>
    </nav>
    <hr>

    <!-- Main Content -->
    <section class="main-content">
        <!-- Create Post Button -->
        <a href="/posts/new" class="create-post-btn">+ Create Post</a>

        <!-- View all the posts here -->
        <% if (posts.length === 0) { %>
            <p class="no-posts">No posts yet. Be the first to create a post!</p>
        <% } else { %>
            <% for (let i = 0; i < posts.length; i++) { %>
                <div class="post-card">
                    <!-- Vote Column -->
                    <div class="vote-column">
                        <!-- Upvote form -->
                        <form action="/vote" method="POST">
                            <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                            <input type="hidden" name="value" value="1">
                            <button type="submit" style="background: none; border: none; color: <%= posts[i].userVote === 1 ? '#00FF00' : '#888' %>; cursor: pointer; font-size: 18px;">&#9650;</button>
                        </form>
                        
                        <!-- Vote Score -->
                        <span class="vote-score"><%= posts[i].score %></span>

                        <!-- Downvote form -->
                        <form action="/vote" method="POST">
                            <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                            <input type="hidden" name="value" value="1">
                            <button type="submit" style="background: none; border: none; color: <%= posts[i].userVote === -1 ? '#FA003F' : '#888' %>; cursor: pointer; font-size: 18px;">&#9660;</button>
                        </form>
                    </div>

                    <!-- Post Content -->
                    <div class="post-content">
                        <a href="" class="post-title">
                            <h3><%= posts[i].title %></h3>
                        </a>
                        <p class="post-author"><%= posts[i].author.username %></p>
                        <p class="post-body"><%= posts[i].body %></p>
                        <p class="post-comment-count"><%= posts[i].commentCount %> Comments</p>
                    </div>
                </div>
            <% } %>
        <% } %>
    </section>

</body>
</html>