<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>

    <section class="main-content">
        <div class="home-actions">
            <a href="/posts/new" class="create-post-btn">+ Create Post</a>
            <a href="/communities" class="create-post-btn">All Communities</a>
        </div>

        <% if (homeError) { %>
            <p class="msg-error"><strong><%= homeError %></strong></p>
        <% } %>

        <% if (homeSuccess) { %>
            <p class="msg-success"><strong><%= homeSuccess %></strong></p>
        <% } %>

        <% if (posts.length === 0) { %>
            <p class="no-posts">No posts yet. Be the first to create a post!</p>
        <% } else { %>
            <% for (let i = 0; i < posts.length; i++) { %>
                <div class="post-card">
                    <div class="vote-column">
                        <form action="/vote" method="POST">
                            <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                            <input type="hidden" name="value" value="1">
                            <button type="submit" class="vote-btn <%= posts[i].userVote === 1 ? 'vote-btn--active-up' : '' %>">&#9650;</button>
                        </form>

                        <span class="vote-score"><%= posts[i].score %></span>

                        <form action="/vote" method="POST">
                            <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                            <input type="hidden" name="value" value="-1">
                            <button type="submit" class="vote-btn <%= posts[i].userVote === -1 ? 'vote-btn--active-down' : '' %>">&#9660;</button>
                        </form>
                    </div>

                    <div class="post-content">
                        <% if (!posts[i].communityId) { %>
                            <h3>No community</h3>
                        <% } else { %>
                            <a href="/communities/<%= posts[i].communityId.name %>" class="community-title">
                                <h3><%= posts[i].communityId.name %></h3>
                            </a>
                        <% } %>

                        <a href="/posts/<%= posts[i]._id%>" class="post-title">
                            <h3><%= posts[i].title %></h3>
                        </a>
                        <p class="post-author"><%= posts[i].author.username %></p>
                        <p class="post-body"><%= posts[i].content %></p>
                        <p class="post-comment-count"><%= posts[i].commentCount %> Comments</p>

                        <% if (posts[i].authorId && posts[i].authorId._id && posts[i].authorId._id.toString() === user_id.toString()) { %>
                            <div class="post-actions">
                                <a href="/posts/<%= posts[i]._id %>">Edit</a>
                                <form action="/deletepost" method="POST" class="post-actions__form" onsubmit="return confirm('Delete this post forever?')">
                                    <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                                    <button type="submit" class="post-actions__delete">Delete</button>
                                </form>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% } %>
        <% } %>
    </section>

</body>
</html>



