<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-page">
        <div class="form-card">
            <form action="/login" method="post">
                <h1>Login</h1>
                <strong><%- loginMsg %></strong>
                <div class="form-field">
                    <label>Username/Email</label>
                    <input type="text" name="loginCred" value="<%= loginCred %>" required>
                </div>
                <div class="form-field">
                    <label>Password</label>
                    <input type="password" name="password" required>
                </div>
                <input type="submit" value="Log in">
            </form>
            <p class="text-small"><a href="/forgetPass">FORGET PASSWORD</a></p>
            <p>Don't have an account yet? Register <a href="/register">here.</a></p>
        </div>
    </div>
</body>
</html>



