<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post</title>
</head>
<body>
    <!--only when the post exists, then the user can edit or delete-->
    <%  if (typeof post !== "undefined" && post !== null) {%>
        <!--post exists-->
        <% if (post.authorId && post.authorId._id.toString() === currentUserId) {%>
        <!--author view-->
        <h3>Edit Post</h3>
        <form action="/updatepost" method="POST">
            <input type="hidden" name="postId" value="<%= post._id %>">
            <input type="text" name="title" value="<%= post.title %>"><br><br>
            <textarea name="content"><%= post.content %></textarea><br><br>
            <button type="submit">Save Changes</button>
        </form>

        <br>

        <h3>Delete Post</h3>
        <form action="/deletepost" method="POST" onsubmit="return confirm('Delete this post forever?')">
            <input type="hidden" name="postId" value="<%= post._id %>">
            <button type="submit">Delete Post</button>
        </form>

        <% } else {%>
            <!--Visitor View-->
            <h3><%= post.title %></h3>
            <p><%= post.content %></p>
            <p><em>Author ID: <%= post.authorId._id %></em></p>
            <p>(You are viewing this post in read-only mode)</p>

            <% } %>
        
    <% } else {%>
        <!--post does not exist-->
    <h3>Create Post</h3>
    <form action="/createpost" method="POST">
        <!-- Input field for post title -->
        <input type="text" name="title" placeholder="Title" required><br><br>
        <!-- Text area for post content -->
        <textarea name="content" placeholder="Write something..." required></textarea><br><br>
        <!-- Optional: community ID -->
        <label for="community">Choose a community:</label>
        <select name="communityId" required>
            <option value="" disabled selected>Select a community</option>
            <% communityList.forEach(c=> { %> <!--Show the array of data community is providing from the database-->
                <option value="<%= c._id %>">r/<%= c.name %></option> <!--When submit, it shows the databaseID to the server, c.name is the visible text -> print the data directly onto thge webpage-->
            <!--r/ identifies the community-->
            <% }) %>
        </select>
        <br><br>
        <button type="submit">Create Post</button>
    </form>
<% } %>
    <br>
    <a href="/">Back to Home</a>
</body>
</html>