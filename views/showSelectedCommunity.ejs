<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WADsUp</title>
    <link rel="icon" type="image/png" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navbar -->
    <%- include('header') %>

    <!-- Main Content -->
    <section class="main-content">
        <!-- back buttons -->
        <p style="color: #fff; margin-bottom: 12px;"><a href="/" style="color: #9ec5ff;">← Back to home</a></p>
        <p style="color: #fff; margin-bottom: 12px;"><a href="/communities" style="color: #9ec5ff;">← Back to communities</a></p>

        <!-- Selected Community Label -->
        
        <div class="selected-community-label">
            <div class="community-label-row">
                <span class="community-label-title"><%= community.name %></span>
                <% if (isCreator) { %>
                <details class="community-menu">
                    <summary class="community-menu-trigger" aria-label="Community options">⋯</summary>
                    <div class="community-menu-dropdown">
                        <a href="/communities/<%= community.name %>/edit" class="community-menu-item">Update community</a>
                        <form action="/communities/<%= community.name %>/delete" method="post" class="community-menu-delete-form"
                              onsubmit="return confirm('Delete this community and all posts in it?');">
                            <button type="submit" class="community-menu-item community-menu-danger">Delete community</button>
                        </form>
                    </div>
                </details>
                <% } %>
            </div>
            <p class="community-label-description"><%= community.description %></p>
        </div>

        <!-- View all the posts here -->
        <% if (posts.length === 0) { %>
            <p class="no-posts">No posts yet. Be the first to create a post!</p>
        <% } else { %>
            <% for (let i = 0; i < posts.length; i++) { %>
                <div class="post-card">
                    <!-- Vote Column -->
                    <div class="vote-column">
                        <!-- Upvote form -->
                        <form action="/vote" method="POST">
                            <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                            <input type="hidden" name="value" value="1">
                            <button type="submit" style="background: none; border: none; color: <%= posts[i].userVote === 1 ? '#00FF00' : '#888' %>; cursor: pointer; font-size: 18px;">&#9650;</button>
                        </form>
                        
                        <!-- Vote Score -->
                        <span class="vote-score"><%= posts[i].score %></span>

                        <!-- Downvote form -->
                        <form action="/vote" method="POST">
                            <input type="hidden" name="postId" value="<%= posts[i]._id %>">
                            <input type="hidden" name="value" value="-1">
                            <button type="submit" style="background: none; border: none; color: <%= posts[i].userVote === -1 ? '#FA003F' : '#888' %>; cursor: pointer; font-size: 18px;">&#9660;</button>
                        </form>
                    </div>

                    <!-- Post Content -->
                    <div class="post-content">
                                                        
                        <a href="/communities/<%= posts[i].communityId.name %>" class="community-title">
                            <h3><%= posts[i].communityId.name %></h3>
                        </a>

                        <a href="/posts/<%= posts[i]._id %>" class="post-title">
                            <h3><%= posts[i].title %></h3>
                        </a>

                        <p class="post-author"><%= posts[i].author.username %></p>
                        <p class="post-body"><%= posts[i].content %></p>
                        <p class="post-comment-count"><%= posts[i].commentCount %> Comments</p>
                    </div>
                </div>
            <% } %>
        <% } %>
    </section>

</body>
</html>
