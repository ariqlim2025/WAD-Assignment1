<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Post: <%= currentPost.title %></title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>

    <div class="post-page">

        <div class="post-card">
            <h1 class="post-title"><%= currentPost.title %></h1>
            <p class="post-meta">posted by u/<%= currentPost.authorId.username %> in <%= community.name %></p>
            <p class="post-body"><%= currentPost.content %></p>

            <% if (isBookmarked) { %>
                <p><strong>Added to Bookmarks</strong></p>
                <a href="/bookmarks" class="btn btn--outline">View Bookmarks</a>
            <% } else { %>
                <form action="/addBookmark" method="GET">
                    <input type="hidden" name="postId" value="<%= currentPost._id %>">
                    <button type="submit" class="btn btn--outline">Add to Bookmarks</button>
                </form>
            <% } %>

            <% if (currentPost.authorId && currentPost.authorId._id && currentPost.authorId._id.toString() === user_id.toString()) { %>
                <h3>Edit Post</h3>
                <p class="msg-error"><%= postMsg %></p>
                <form action="/updatepost" method="POST">
                    <input type="hidden" name="postId" value="<%= currentPost._id %>">
                    <input type="hidden" name="communityid" value="<%= currentPost.communityId %>">
                    <div class="form-field">
                        <input type="text" name="title" value="<%= currentPost.title %>" class="form-input">
                    </div>
                    <div class="form-field">
                        <textarea name="content" class="form-textarea"><%= currentPost.content %></textarea>
                    </div>
                    <button type="submit" class="form-submit">Save Changes</button>
                </form>

                <h3>Delete Post</h3>
                <form action="/deletepost" method="POST" onsubmit="return confirm('Delete this post forever?')">
                    <input type="hidden" name="postId" value="<%= currentPost._id %>">
                    <button type="submit" class="btn btn--danger">Delete Post</button>
                </form>
            <% } %>
        </div>

        <% for (let error of errors) { %>
            <p class="msg-error"><%= error %></p>
        <% } %>

        <div class="comments-section">
            <h2>Comments (<%= currentComments.length %>)</h2>

            <% currentComments.forEach((comment) => { %>
                <div class="comment">
                    <p class="comment-author">u/<%= comment.authorId.username %></p>
                    <p class="comment-text"><%= comment.content %></p>

                    <% if (comment.authorId._id.toString() === user_id) { %>
                        <form action="/posts/<%= currentPost._id %>/edit-comment" method="GET">
                            <input type="hidden" name="commentId" value="<%= comment._id %>" required>
                            <button type="submit" class="link-btn">Edit</button>
                        </form>

                        <form action="/posts/<%= currentPost._id %>/delete-comment" method="POST">
                            <input type="hidden" name="commentId" value="<%= comment._id %>" required>
                            <button type="submit" class="link-btn">Delete</button>
                        </form>
                    <% } %>
                </div>
            <% }) %>

            <div class="comment-form-wrapper">
                <h3>Leave a comment</h3>
                <form action="/posts/<%= currentPost._id %>/" method="post">
                    <textarea name="newComment" rows="4" placeholder="What are your thoughts?" required></textarea>
                    <button type="submit">Post Comment</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>



