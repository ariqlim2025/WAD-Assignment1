<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Comment</title>
    <link rel="icon" type="image/png" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .edit-page {
            max-width: 780px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .post-card {
            padding: 30px;
            margin-bottom: 24px;
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .post-title {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .post-meta {
            font-size: 0.8rem;
            color: #888;
        }

        .post-body {
            font-size: 0.95rem;
            line-height: 1.7;
            color: #444;
        }

        .edit-form-wrapper {
            background: #fff8f0;
            border: 1px solid #f5c8a0;
            border-left: 3px solid #e07b00;
            border-radius: 8px;
            padding: 24px;
            margin-top: 8px;
        }

        .edit-form-wrapper h3 {
            font-size: 0.85rem;
            font-weight: 600;
            color: #e07b00;
            margin-bottom: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .edit-form-wrapper textarea {
            width: 95%;
            padding: 12px;
            border: 1px solid #f5c8a0;
            border-radius: 6px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.9rem;
            resize: vertical;
            outline: none;
            background: #fffaf5;
            min-height: 120px;
        }

        .edit-form-wrapper textarea:focus {
            border-color: #e07b00;
        }

        .edit-form-wrapper button {
            margin-top: 10px;
            background: #e07b00;
            color: white;
            border: none;
            border-radius: 6px;
            padding: 10px 22px;
            font-family: 'Poppins', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
        }

        .edit-form-wrapper button:hover {
            background: #c46a00;
        }
    </style>
</head>
<body>
    <%- include('header') %>

    <div class="edit-page">
        <div class="post-card">
            <h1 class="post-title"><%= currentPost.title %></h1>
            <p class="post-meta">posted by u/<%= currentPost.authorId.username %> in <%= community %></p>
            <p class="post-body"><%= currentPost.content %></p>
        </div>

        <div class="edit-form-wrapper">
            <h3>Editing Comment</h3>
            <form action="./edit-comment" method="POST">
                <input type="hidden" name="commentId" value="<%= currentComment._id %>">
                <textarea name="newComment"><%= currentComment.content %></textarea><br>
                <button type="submit">Make Changes</button>
            </form>
        </div>
    </div>

</body>
</html>