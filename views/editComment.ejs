<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Comment</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('header') %>

    <div class="edit-page">
        <div class="post-card">
            <h1 class="post-title"><%= currentPost.title %></h1>
            <p class="post-meta">posted by u/<%= currentPost.authorId.username %> in <%= community %></p>
            <p class="post-body"><%= currentPost.content %></p>
        </div>

        <% for (let error of errors) { %>
            <p class="msg-error"><%= error %></p>
        <% } %>

        <div class="edit-form-wrapper">
            <h3>Editing Comment</h3>
            <form action="/posts/<%= currentPost._id %>/edit-comment" method="POST">
                <input type="hidden" name="commentId" value="<%= currentComment._id %>">
                <textarea name="newComment" required><%= currentComment.content %></textarea>
                <button type="submit">Edit Comment</button>
            </form>
        </div>
    </div>

</body>
</html>



