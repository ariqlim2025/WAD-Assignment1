<html>
<head></head>
<body>

  <h1>Add Bookmark</h1>
  <hr>
  <p>
    <a href="/posts/<%= postId %>">Back to Post</a>
    &nbsp;|&nbsp;
    <a href="/bookmarks">Back to Bookmarks</a>
    &nbsp;|&nbsp;
    <a href="/">Back to Home</a>
  </p>

  <% if (bookmarkError) { %>
    <p style="color: #c62828;"><strong><%= bookmarkError %></strong></p>
  <% } %>

<%- // gonna add post title and post content later %>

  <form action="/bookmarks" method="post">
    <input type="hidden" name="postId" value="<%= postId %>">
    <p><label for="note"><strong>Note</strong></label></p>
    <textarea name="note" id="note" rows="4" cols="40" placeholder="Write your note here" required></textarea>
    <br><br>
    <button type="submit">Save Bookmark</button>
  </form>

</body>
</html>
