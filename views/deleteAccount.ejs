<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wadsup</title>
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/app-logo-2.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/app-logo-2.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/app-logo-2.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="auth-page">
        <div class="form-card">
            <form action="/deleteAccount" method="post" <%= accountDeleted ? "hidden" : "" %>>
                <h1>Are you sure?</h1>
                <h3>Input your password to confirm</h3>
                <p class="msg-error"><strong><%= passError %></strong></p>
                <div class="form-field">
                    <input type="password" name="password" required>
                </div>
                <input type="submit" value="Delete Account">
                <a href="/profile"><input type="button" value="Cancel"></a>
            </form>
            <div <%= accountDeleted ? "" : "hidden" %>>
                <h2>Your account has been deleted, thank you for having been part of Wadsup!</h2>
                <p><a href="/login">Return back to login</a></p>
            </div>
        </div>
    </div>
</body>
</html>



